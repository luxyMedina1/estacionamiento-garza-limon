<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estacionamiento - Panel de Control</title>
    <!-- Tipografía ultra moderna -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0f1115;       
            --bg-card: #181a20;       
            --bg-input: #22252d;     
            --text-main: #f3f4f6;     
            --text-muted: #9ca3af;    
            --border: #2d3139;        
            
            
            --primary: #a855f7;       
            --primary-hover: #c084fc;
            --danger: #ef4444;
            --success: #10b981;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            padding: 2.5rem 1.5rem;
        }

        .container-wrapper {
            max-width: 1100px;
            margin: 0 auto;
        }

        /* Header Minimalista */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

        h1 {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-main);
        }

        .btn-link {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: color 0.2s ease;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            background-color: var(--bg-card);
            border: 1px solid var(--border);
        }

        .btn-link:hover {
            color: var(--text-main);
            border-color: var(--text-muted);
        }

        /* Alertas limpias */
        .alert-success {
            color: var(--success);
            background: rgba(16, 185, 129, 0.06);
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
            margin-bottom: 2rem;
            font-weight: 500;
            font-size: 0.95rem;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .alert-danger {
            color: var(--danger);
            background: rgba(239, 68, 68, 0.06);
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
            margin-bottom: 2rem;
            font-weight: 500;
            font-size: 0.95rem;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        /* Grid de Paneles */
        .grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin-bottom: 2.5rem;
        }

        @media (min-width: 768px) {
            .grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .box {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 2.25rem;
        }

        h2 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 1.75rem;
            color: var(--text-main);
            letter-spacing: -0.01em;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        input, select {
            width: 100%;
            padding: 0.85rem 1rem;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 0.6rem;
            color: var(--text-main);
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--text-muted);
            background-color: var(--bg-main);
        }

        /* Botones Estilizados */
        button {
            width: 100%;
            padding: 0.85rem;
            border: none;
            border-radius: 0.6rem;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            background: var(--text-main);
            color: var(--bg-main);
        }

        button:hover {
            filter: brightness(0.9);
            transform: translateY(-1px);
        }

        .btn-salida {
            background: transparent;
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-salida:hover {
            background: rgba(239, 68, 68, 0.08);
            border-color: var(--danger);
            color: var(--danger);
        }

        /* Sección de Tabla Minimalista */
        .table-section {
            margin-top: 2.5rem;
        }

        .table-section h2 {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .counter {
            font-size: 0.85rem;
            background-color: var(--bg-input);
            color: var(--text-muted);
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            border: 1px solid var(--border);
        }

        .table-container {
            width: 100%;
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 1rem;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.95rem;
        }

        th {
            background-color: rgba(34, 37, 45, 0.4);
            padding: 1rem 1.5rem;
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            color: var(--text-main);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background-color: rgba(34, 37, 45, 0.3);
        }

        .badge-tipo {
            font-size: 0.8rem;
            color: var(--text-muted);
            background: var(--bg-input);
            padding: 0.2rem 0.5rem;
            border-radius: 0.4rem;
            border: 1px solid var(--border);
        }
    </style>
</head>
<body>

    <div class="container-wrapper">
        <!-- Encabezado -->
        <header>
            <h1>Control de Estacionamiento</h1>
            <a href="/reportes" class="btn-link"> Ver Reportes</a>
        </header>

        <!-- Mensajes de feedback -->
        <% if (mensaje) { %> 
            <div class="alert-success"><%= mensaje %></div> 
        <% } %>
        <% if (error) { %> 
            <div class="alert-danger"><%= error %></div> 
        <% } %>

        <div class="grid">
            <!-- Registrar Entrada -->
            <div class="box">
                <h2> Registrar Entrada</h2>
                <form action="/entrada" method="POST">
                    <div class="form-group">
                        <label>Número de Placa</label>
                        <input type="text" name="placa" placeholder="Introduce la placa" required autocomplete="off" style="text-transform: uppercase;">
                    </div>
                    <div class="form-group">
                        <label>Tipo de Vehículo</label>
                        <select name="tipo_id" required>
                            <% tipos.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.nombre %> ($<%= t.tarifa_por_minuto %>/min)</option>
                            <% }) %>
                        </select>
                    </div>
                    <button type="submit">Ingresar Vehículo</button>
                </form>
            </div>

            <!-- Registrar Salida -->
            <div class="box">
                <h2>📤 Registrar Salida</h2>
                <form action="/salida" method="POST">
                    <div class="form-group">
                        <label>Número de Placa</label>
                        <input type="text" name="placa" placeholder="Introduce la placa" required autocomplete="off" style="text-transform: uppercase;">
                    </div>
                    <button type="submit" class="btn-salida">Cobrar y Dar Salida</button>
                </form>
            </div>
        </div>

        <!-- Tabla de Activos -->
        <div class="table-section">
            <div class="box" style="padding: 0; overflow: hidden; border-radius: 1rem;">
                <div style="padding: 1.5rem 2.25rem; background: var(--bg-card); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                    <h2 style="margin: 0; font-size: 1.1rem;">Vehículos en el Interior</h2>
                    <span class="counter"><%= activos.length %> activos</span>
                </div>
                <div class="table-container" style="border: none; border-radius: 0;">
                    <table>
                        <thead>
                            <tr>
                                <th>Placa</th>
                                <th>Tipo de Vehículo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% activos.forEach(a => { %>
                                <tr>
                                    <td><strong style="color: var(--text-main); font-weight: 600; letter-spacing: 0.02em;"><%= a.placa %></strong></td>
                                    <td><span class="badge-tipo"><%= a.tipo %></span></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>
</html>