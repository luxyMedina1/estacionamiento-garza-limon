<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes del Sistema</title>
    <!-- Tipografía ultra moderna idéntica al panel principal -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0f1115;       /* Gris casi negro */
            --bg-card: #181a20;       /* Gris oscuro contenedores */
            --bg-input: #22252d;      /* Gris medio para inputs */
            --text-main: #f3f4f6;     /* Blanco grisáceo */
            --text-muted: #9ca3af;    /* Gris claro */
            --border: #2d3139;        /* Gris sutil */
            
            --success: #10b981;       /* Verde excel */
            --danger: #ef4444;        /* Rojo pdf */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            padding: 2.5rem 1.5rem;
        }

        .container-wrapper {
            max-width: 1100px;
            margin: 0 auto;
        }

        /* Header Minimalista sin emojis */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

        h1 {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-main);
        }

        .btn-link {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: color 0.2s ease, border-color 0.2s ease;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            background-color: var(--bg-card);
            border: 1px solid var(--border);
        }

        .btn-link:hover {
            color: var(--text-main);
            border-color: var(--text-muted);
        }

        .box {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 2.25rem;
            margin-bottom: 2.5rem;
        }

        /* Formulario de filtros */
        .filter-form {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.25rem;
            align-items: end;
        }

        @media (min-width: 768px) {
            .filter-form {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        input {
            width: 100%;
            padding: 0.85rem 1rem;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 0.6rem;
            color: var(--text-main);
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--text-muted);
            background-color: var(--bg-main);
        }

        button {
            width: 100%;
            padding: 0.85rem;
            border: none;
            border-radius: 0.6rem;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            background: var(--text-main);
            color: var(--bg-main);
        }

        button:hover {
            filter: brightness(0.9);
            transform: translateY(-1px);
        }

        /* Contenedor de descargas */
        .download-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .btn-download {
            padding: 0.75rem 1.25rem;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            border-radius: 0.6rem;
            transition: all 0.2s ease;
            text-align: center;
        }

        .btn-excel {
            background: transparent;
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .btn-excel:hover {
            background: rgba(16, 185, 129, 0.08);
            border-color: var(--success);
        }

        .btn-pdf {
            background: transparent;
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-pdf:hover {
            background: rgba(239, 68, 68, 0.08);
            border-color: var(--danger);
        }

        /* Estilos de la tabla */
        .table-container {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 0.75rem;
            overflow: hidden;
            margin-top: 1.5rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.95rem;
        }

        th {
            background-color: rgba(34, 37, 45, 0.4);
            padding: 1rem 1.5rem;
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            color: var(--text-main);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background-color: rgba(34, 37, 45, 0.3);
        }

        .badge-tipo {
            font-size: 0.8rem;
            color: var(--text-muted);
            background: var(--bg-input);
            padding: 0.2rem 0.5rem;
            border-radius: 0.4rem;
            border: 1px solid var(--border);
        }
    </style>
</head>
<body>

    <div class="container-wrapper">
        <!-- Encabezado Minimalista -->
        <header>
            <h1>Generación de Reportes</h1>
            <a href="/" class="btn-link">Regresar al Panel Principal</a>
        </header>

        <div class="box">
            <!-- Formulario con Grid Adaptable -->
            <form action="/reportes/buscar" method="GET" class="filter-form">
                <div class="form-group">
                    <label>Fecha</label>
                    <input type="date" name="fecha" required value="<%= query.fecha || '' %>">
                </div>
                <div class="form-group">
                    <label>Hora Inicio</label>
                    <input type="time" name="hora_inicio" required value="<%= query.hora_inicio || '13:00' %>">
                </div>
                <div class="form-group">
                    <label>Hora Fin</label>
                    <input type="time" name="hora_fin" required value="<%= query.hora_fin || '17:00' %>">
                </div>
                <button type="submit">Filtrar</button>
            </form>

            <!-- Resultados condicionales -->
            <% if (filtrado) { %>
                <div class="download-actions">
                    <a class="btn-download btn-excel" href="/reportes/excel?fecha=<%= query.fecha %>&hora_inicio=<%= query.hora_inicio %>&hora_fin=<%= query.hora_fin %>">Descargar Excel</a>
                    <a class="btn-download btn-pdf" href="/reportes/pdf?fecha=<%= query.fecha %>&hora_inicio=<%= query.hora_inicio %>&hora_fin=<%= query.hora_fin %>">Descargar PDF</a>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Núm. Placa</th>
                                <th>Tiempo Estacionado</th>
                                <th>Tipo</th>
                                <th>Cantidad a Pagar</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% datos.forEach(d => { %>
                                <tr>
                                    <td><strong style="color: var(--text-main); font-weight: 600;"><%= d.placa %></strong></td>
                                    <td><%= d.minutos %> min</td>
                                    <td><span class="badge-tipo"><%= d.tipo %></span></td>
                                    <td style="font-weight: 600; color: var(--text-main);">$<%= d.monto_pagado %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>